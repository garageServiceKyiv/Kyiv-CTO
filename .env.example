# Telegram Bot
# Створіть бота через @BotFather в Telegram і отримайте токен
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ID чату або групи, куди будуть приходити заявки
# Напишіть боту @userinfobot щоб дізнатися свій chat ID
TELEGRAM_CHAT_ID=your_chat_id_here

# Секрет для верифікації webhook (довільний рядок, задається при реєстрації webhook)
TELEGRAM_WEBHOOK_SECRET=your_random_secret_here

# Cloudinary (https://cloudinary.com — безкоштовно)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
